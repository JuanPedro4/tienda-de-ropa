# ──────────────────────────────────────────────
# Tienda de Ropa Infantil — Environment Variables
# ──────────────────────────────────────────────

# Database
DATABASE_URL="postgresql://tienda_user:tienda_pass@localhost:5432/tienda_ropa"

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_CACHE_TTL=300

# Auth.js v5
AUTH_SECRET="change-me-to-a-random-secret-at-least-32-chars"
AUTH_URL="http://localhost:3000"

# Google OAuth (from Google Cloud Console)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Medusa.js
MEDUSA_BACKEND_URL="http://localhost:9000"
MEDUSA_API_KEY=""
MEDUSA_JWT_SECRET="change-me"

# Storefront
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_MEDUSA_BACKEND_URL="http://localhost:9000"

# Cloudinary (images)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ISR revalidation secret
REVALIDATION_SECRET="change-me-to-a-random-secret"

# Resend (transactional emails)
RESEND_API_KEY=""
